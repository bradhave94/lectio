{
	"name": "@repo/database",
	"version": "0.0.0",
	"main": "./index.ts",
	"types": "./**/.tsx",
	"scripts": {
		"clean": "git clean -xdf .cache .turbo dist node_modules",
		"generate": "dotenv -c -e ../../.env -- drizzle-kit generate --config ./drizzle/drizzle.config.ts",
		"push": "dotenv -c -e ../../.env -- drizzle-kit push --config ./drizzle/drizzle.config.ts",
		"migrate": "dotenv -c -e ../../.env -- drizzle-kit migrate --config ./drizzle/drizzle.config.ts",
		"studio": "dotenv -c -e ../../.env -- drizzle-kit studio --config ./drizzle/drizzle.config.ts",
		"type-check": "tsc --noEmit"
	},
	"dependencies": {
		"@paralleldrive/cuid2": "^3.3.0",
		"drizzle-orm": "catalog:",
		"drizzle-zod": "catalog:",
		"pg": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@repo/tsconfig": "workspace:*",
		"@types/node": "catalog:",
		"dotenv": "catalog:",
		"dotenv-cli": "catalog:",
		"drizzle-kit": "catalog:"
	}
}
